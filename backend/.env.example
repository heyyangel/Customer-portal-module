# Shardha Impex Customer Portal - Environment Variables

# MongoDB Connection URI
MONGO_URI=mongodb://localhost:27017/erp_portal

# Server Port
PORT=5000
FRONTEND_URL=http://localhost:5173

# JWT Secret Key
JWT_SECRET=supersecret123
JWT_EXPIRES_IN=1d

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
EMAIL_FROM="ERP Portal <no-reply@example.com>"

# Node Environment
NODE_ENV=development
